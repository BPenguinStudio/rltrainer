# ──────────────────────────────────────────────────────────────
#  RL Trainer — environment configuration
#  Copy this file to ".env" and fill in your values, OR export
#  these variables in your shell / hosting provider.
#
#  The site runs WITHOUT any of these set — it will offer a
#  "Try a Demo Profile" login. Configure the Discord values
#  below to enable real "Log in with Discord".
# ──────────────────────────────────────────────────────────────

# Port the server listens on (default 3000)
PORT=3000

# The public base URL of your site (used to build the OAuth redirect).
# For local dev this is http://localhost:3000
PUBLIC_URL=http://localhost:3000

# ── Discord OAuth2 ────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
#   1. New Application -> copy the "Application ID"  => DISCORD_CLIENT_ID
#   2. OAuth2 tab -> reset/copy "Client Secret"      => DISCORD_CLIENT_SECRET
#   3. OAuth2 tab -> Redirects -> add:
#        <PUBLIC_URL>/auth/discord/callback
#      e.g. http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional: override the redirect URI if it differs from
# <PUBLIC_URL>/auth/discord/callback
# DISCORD_REDIRECT_URI=

# ── Security ──────────────────────────────────────────────────
# Secret used to sign session cookies. If left blank, a random
# one is generated and stored in data/.session-secret
SESSION_SECRET=
